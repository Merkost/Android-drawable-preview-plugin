# Marketplace publishing secrets — copy this file to .env and fill in.
# .env is gitignored; .env.example is committed so contributors know which
# variables to set.
#
# Use:
#   cp .env.example .env
#   chmod 600 .env
#   # edit .env, paste your token
#   ./scripts/publish.sh             # convenience wrapper
#   # or: set -a; source .env; set +a; ./gradlew publishPlugin

# Token from https://plugins.jetbrains.com/author/me/tokens (Generate Permanent Token).
JETBRAINS_MARKETPLACE_TOKEN=

# Channel: default | eap | beta | … (default = stable)
JETBRAINS_MARKETPLACE_CHANNEL=default

# Optional: signing key. If any of these is unset, signPlugin is silently
# skipped and the plugin ships unsigned (Marketplace accepts it; users see
# a "from unverified author" notice on install).
JETBRAINS_PLUGIN_CERT_CHAIN_FILE=
JETBRAINS_PLUGIN_PRIVATE_KEY_FILE=
JETBRAINS_PLUGIN_PRIVATE_KEY_PASSWORD=
